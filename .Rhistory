library(tidyverse)
#| message: false
theme_set(theme_gray(base_size = 9,
base_family = "HiraginoSans-W3"))
coin <- c("表", "裏")  # コインを定義する
coin
sample(coin, size = 1)
sample(coin, size = 1)
sample(coin, size = 1)
sample(coin, size = 1)
sample(coin, size = 1)
sample(coin, size = 1)
sample(coin, size = 2)
sample(coin)
sample(coin, size = 2)
#| error: true
sample(coin, size = 3)
sample(coin, size = 5, replace = TRUE)
coin10 <- sample(coin, size = 10, replace = TRUE) |>
print()
a <- 2    # aに2を代入する
a == 2
a == 3
a == "裏" # 文字列と比べるときは文字列を引用符で囲む
coin10 == "表"
sum(coin10 == "表")
#| echo: false
set.seed(12345)
coin100 <- sample(coin, size = 100, replace = TRUE)
table(coin100)
table(coin100) / 100
sum(table(coin100) / 100) == 1
table(coin100) / length(coin100)
proportions(table(coin100))
coin100 |>
table() |>
proportions()
D <- tibble(res = coin100)
bar_coin <- ggplot(D, aes(x = res)) +
geom_bar(color = "black", width = 0.3) +
labs(x = "結果", y = "回数")
plot(bar_coin)
D <- D |>
mutate(res2 = ifelse(res == "表", 1, 0))
with(D, table(res, res2))
bar_coin2 <- ggplot(D, aes(x = res2)) +
geom_histogram(color = "black", binwidth = 0.5) +
labs(x = "結果", y = "回数") +
scale_x_continuous(breaks = 0 : 1,
minor_breaks = NULL)
plot(bar_coin2)
bar_coin2 <- ggplot(D, aes(x = res2)) +
geom_histogram(color = "black", binwidth = 0.5, bins = 2) +
labs(x = "結果", y = "回数") +
scale_x_continuous(breaks = 0 : 1,
minor_breaks = NULL)
plot(bar_coin2)
bar_coin2 <- ggplot(D, aes(x = res2)) +
geom_histogram(color = "black", bins = 2) +
labs(x = "結果", y = "回数") +
scale_x_continuous(breaks = 0 : 1,
minor_breaks = NULL)
plot(bar_coin2)
hist_coin <- ggplot(D, aes(x = res2, y = after_stat(density))) +
geom_histogram(color = "black", bins = 2) +
labs(x = "結果", y = "割合") +
scale_x_continuous(breaks = 0 : 1,
minor_breaks = NULL)
plot(hist_coin)
hist_coin2 <- ggplot(D, aes(x = res2, y = after_stat(density))) +
geom_histogram(color = "black", bins = 2) +
labs(x = "結果", y = "割合") +
scale_x_continuous(breaks = 0 : 1,
minor_breaks = NULL)
plot(hist_coin2)
