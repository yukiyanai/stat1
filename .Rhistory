data(mtcars)
glimpse(mtcars)
is.data.frame(mtcars)
#| echo: false
?mtcars
#| message: false
library(tidyverse)
#| include: false
my_font <- "HiraginoSans-W3"
theme_set(theme_gray(base_size = 9,
base_family = my_font))
p1_1 <- ggplot(data = mtcars,
mapping = aes(x = wt, y = mpg))
plot(p1_1)
p1_2 <- p1_1 +
geom_point()
plot(p1_2)
p1_3 <- p1_2 +
labs(x = "重量 (1000 lbs)",
y = "燃費 (Miles / US gallon)")
plot(p1_3)
p1 <- ggplot(mtcars, aes(x = wt, y = mpg)) +
geom_point() +
labs(x = "重量 (1000 lbs)",
y = "燃費 (Miles / US gallon)")
plot(p1)
p2_1 <- ggplot(mtcars, aes(x = mpg))
plot(p2_1)
p2_2 <- p2_1 +
geom_histogram()
plot(p2_2)
p2_3 <- p2_1 +
geom_histogram(binwidth = 2.5)
plot(p2_3)
p2_4 <- p2_1 +
geom_histogram(binwidth = 2.5, color = "black")
plot(p2_4)
p2_5 <- p2_1 +
geom_histogram(binwidth = 2.5,
color = "black",
boundary = 5)
plot(p2_5)
p2_6 <- p2_5 +
labs(x = "燃費 (Miles / US gallon)", y = "度数")
plot(p2_6)
p2_dens <- ggplot(mtcars,
aes(x = mpg,
y = after_stat(density))) +
geom_histogram(binwidth = 2.5,
boundary = 5,
color = "black",
fill = "dodgerblue") +
labs(x = "燃費 (Miles / US gallon)",
y = "確率密度")
plot(p2_dens)
data(diamonds)
glimpse(diamonds)
class(diamonds)
p3_1 <- ggplot(diamonds, aes(x = cut, y = depth))
plot(p3_1)
p3_2 <- p3_1 +
geom_boxplot()
plot(p3_2)
p3_3 <- p3_2 +
labs(x = "カット", y = "深さ")
plot(p3_3)
p3_3a <- diamonds |>
mutate(cut_jp = factor(
cut,
levels = c("Fair", "Good", "Very Good", "Premium", "Ideal"),
labels = c("フェア", "グッド", "ベリーグッド",
"プレミアム", "アイディアル"))) |>
ggplot(aes(x = cut_jp, y = depth)) +
geom_boxplot() +
labs(x = "カット", y = "深さ")
plot(p3_3a)
p3_4 <- p3_3 +
coord_flip()
plot(p3_4)
p4 <- ggplot(diamonds, aes(x = depth, y = cut)) +
geom_boxplot() +
labs(x = "カット", y = "深さ")
plot(p4)
#| message: false
myd <- read_csv("data/fake_score.csv")
glimpse(myd)
bar1 <- ggplot(myd, aes(x = class)) +
geom_bar() +
labs(x = "クラス", y = "人数")
plot(bar1)
bar2 <- bar1 +
scale_x_continuous(breaks = 1:8)
plot(bar2)
bar3 <- ggplot(myd, aes(x = class, fill = gender)) +
geom_bar() +
labs(x = "クラス", y = "人数") +
scale_x_continuous(breaks = 1:8)
plot(bar3)
bar4 <- bar3 +
scale_fill_brewer(palette = "Accent",
name = "性別",
labels = c("女", "男"))
plot(bar4)
bar5 <-  ggplot(myd, aes(x = class, fill = gender)) +
geom_bar(position = "dodge") +
labs(x = "クラス", y = "人数") +
scale_x_continuous(breaks = 1:8) +
scale_fill_brewer(palette = "Set2",
name = "性別",
labels = c("女", "男"))
plot(bar5)
hist1 <- ggplot(myd, aes(x = math)) +
geom_histogram() +
labs(x = "数学の点数", y = "人数")
plot(hist1)
hist2 <- ggplot(myd, aes(x = math)) +
geom_histogram(color = "black") +
labs(x = "数学の点数", y = "人数")
plot(hist2)
hist3 <- ggplot(myd, aes(x = math)) +
geom_histogram(color = "black", binwidth = 10) +
labs(x = "数学の点数", y = "人数")
plot(hist3)
hist4 <- ggplot(myd, aes(x = math, y = after_stat(density))) +
geom_histogram(color = "black", binwidth = 10) +
labs(x = "数学の点数", y = "確率密度")
plot(hist4)
hist5 <- hist3 +
geom_vline(xintercept = mean(myd$math),
color = "red")
plot(hist5)
hist6 <- hist5 +
geom_text(aes(x = 70, y = 90,
label = str_c("平均値：", round(mean(myd$math), 1))),
color = "red",
family = my_font)
#| warning: true
hist6 <- hist5 +
geom_text(aes(x = 70, y = 90,
label = str_c("平均値：", round(mean(myd$math), 1))),
color = "red",
family = my_font)
plot(hist6)
?annotate
#| warning: true
hist6 <- hist5 +
annotate(aes(x = 70, y = 90,
label = str_c("平均値：", round(mean(myd$math), 1))),
color = "red",
family = my_font)
#| warning: true
hist6 <- hist5 +
annotate("text", x = 70, y = 90,
label = str_c("平均値：", round(mean(myd$math), 1))),
#| warning: true
hist6 <- hist5 +
annotate("text", x = 70, y = 90,
label = str_c("平均値：", round(mean(myd$math), 1)),
color = "red",
family = my_font)
plot(hist6)
